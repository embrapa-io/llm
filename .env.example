# Portas no host (Ollama passa pelo nginx; SGLang é mapeado direto)
PORT_OLLAMA=11434
PORT_SGLANG=11435

# Diretório dos modelos do Ollama no host
LLM_PATH=/data/ollama

# =============================================================================
# Ollama (CPU-only) — embeddings
# =============================================================================
# As GPUs ficam dedicadas ao SGLang. O Ollama roda em CPU apenas para servir
# modelos de embedding (bge-m3, qwen3-embedding:0.6b, embeddinggemma:300m,
# granite-embedding:278m). Os 2× Xeon 6730P (Granite Rapids) têm AMX — tiles
# INT8/BF16 que aceleram embeddings no llama.cpp muito além do AVX-512.

# Context window size (default: 2048)
OLLAMA_CONTEXT_LENGTH=16384

# Flash Attention - faster inference
OLLAMA_FLASH_ATTENTION=1

# New inference engine (improved performance)
OLLAMA_NEW_ENGINE=1

# Concurrent Requests (em CPU, com 128 threads disponíveis)
OLLAMA_NUM_PARALLEL=8

# Máximo de modelos simultâneos em memória (256 GB RAM)
OLLAMA_MAX_LOADED_MODELS=4

# Keep models loaded (reduces cold start latency)
OLLAMA_KEEP_ALIVE=24h

# Threads OpenMP por instância. 64 cores físicos ÷ 4 modelos = 16 (estrito);
# 32 dá margem para picos sem oversubscribir os 128 threads lógicos.
OMP_NUM_THREADS=32

# Afinidade NUMA — evita thrashing entre os dois sockets Xeon 6730P.
OMP_PROC_BIND=close
OMP_PLACES=cores

# =============================================================================
# SGLang — Qwen3.6-35B-A3B-FP8 (MoE multimodal + GDN híbrida) em TP=2
# =============================================================================
# Qwen/Qwen3.6-35B-A3B-FP8 (abril/2026, ~37 GiB) é o FP8 oficial da Qwen:
# MoE 35B total / 3B ativos por token, multimodal (early-fusion VLM), atenção
# híbrida GDN (Gated DeltaNet na maioria das camadas + poucas full attention
# → KV cache leve, o que viabiliza contexto de 512K–1M). FP8 fine-grained
# (block 128) roda NATIVO nos L40S (Ada, sm_89) — performance ~idêntica ao
# BF16 original com metade da VRAM. Contexto nativo: 262.144 tokens.

# Token do HuggingFace Hub — recomendado para evitar rate-limiting no download
# e obrigatório para modelos gated. Obter em https://huggingface.co/settings/tokens
# (escopo "Read" é suficiente). Usado pelo ./download-model.sh.
#HF_TOKEN=

# Diretório no host onde o modelo foi baixado (use ./download-model.sh).
SGLANG_MODEL_PATH=/data/models/qwen3.6-35b-a3b-fp8

# Repositório HuggingFace do modelo (usado apenas pelo download-model.sh).
SGLANG_MODEL_REPO=Qwen/Qwen3.6-35B-A3B-FP8

# Nome exposto na API (campo "model" nas requisições)
SGLANG_SERVED_MODEL_NAME=qwen3.6-35b-a3b

# Tensor Parallelism — 2 GPUs (L40S 48 GB)
SGLANG_TP_SIZE=2

# Contexto em tokens. Nativo do modelo: 262144 (262K). Alvos nos 96 GB:
#   262144  — nativo, sem YaRN (zero risco de qualidade) — default
#   524288  — 512K: YaRN factor 2.0 + SGLANG_ALLOW_OVERWRITE_LONGER_CONTEXT_LEN=1
#   1048576 — 1M: YaRN factor 4.0 + idem (reduzir SGLANG_MAX_RUNNING_REQUESTS)
# O SGLang recusa contexto acima do derivado do modelo sem a env de override
# (ValueError no boot — visto em 10/07/2026). Validar QUALIDADE com
# needle-in-haystack ≥300K no hp-gpu02 (dev) antes de promover à produção.
# Conferir no boot: max_total_num_tokens (capacidade real de KV) × slots.
SGLANG_CONTEXT_LENGTH=262144

# Requisições concorrentes (baseado em KV cache disponível). Com 1M de
# contexto, reduzir para 2–4.
SGLANG_MAX_RUNNING_REQUESTS=8

# Batch size máximo dos CUDA graphs — manter = MAX_RUNNING_REQUESTS (graphs
# maiores nunca rodam). Sem isso o warmup do 1º boot captura dezenas de
# graphs e estoura o timeout interno de 600s do SGLang (launcher mata os
# schedulers com SIGKILL — visto em 10/07/2026).
SGLANG_CUDA_GRAPH_MAX_BS=8

# Fração estática da VRAM reservada (default SGLang: 0.88).
SGLANG_MEM_FRACTION=0.90

# GPUs visíveis para o SGLang (vazio = todas)
SGLANG_NVIDIA_VISIBLE_DEVICES=all

# Parsers (por família de modelo).
# Para Qwen3.5/3.6 → reasoning 'qwen3', tool-call 'qwen3_coder' (recomendação
# oficial do model card do Qwen3.6).
SGLANG_REASONING_PARSER=qwen3
SGLANG_TOOL_CALL_PARSER=qwen3_coder

# Permite --context-length acima do derivado do modelo (necessário p/ YaRN).
SGLANG_ALLOW_OVERWRITE_LONGER_CONTEXT_LEN=0

# Flags extras do SGLang — acrescentados no fim do comando.
#
# Receita 512K (testar no hp-gpu02 antes de promover):
#   SGLANG_CONTEXT_LENGTH=524288
#   SGLANG_ALLOW_OVERWRITE_LONGER_CONTEXT_LEN=1
#   SGLANG_EXTRA_ARGS=--json-model-override-args '{"rope_scaling":{"rope_type":"yarn","factor":2.0,"original_max_position_embeddings":262144}}'
# Para 1M: factor 4.0, SGLANG_CONTEXT_LENGTH=1048576 e menos slots.
#
# Outras flags úteis nos L40S (sm_89):
#   --kv-cache-dtype fp8_e4m3 — dobra a capacidade de KV cache (FP8 nativo
#     em Ada); validar qualidade em contexto longo antes de fixar em produção.
# A quantização FP8 do checkpoint é auto-detectada (não passar --quantization).
SGLANG_EXTRA_ARGS=
